{
  "name": "selderey-body-backend",
  "version": "1.0.0",
  "description": "REST API для сайта фитнес-студии Selderey Body (Node.js + Express + PostgreSQL)",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:schema": "node scripts/runSql.js sql/schema.sql",
    "db:seed": "node scripts/runSql.js sql/seed.sql",
    "create:admin": "node scripts/createAdmin.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-validator": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  },
  "engines": {
    "node": ">=18"
  }
}
