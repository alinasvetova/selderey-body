# Скопируйте этот файл в .env и заполните реальными значениями.
# .env в репозиторий не коммитится (см. .gitignore).

# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/selderey_body
# Если хост требует SSL (например, Render/Railway production) — выставьте true
PGSSL=false

# Сервер
PORT=4000
NODE_ENV=development

# Авторизация
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# CORS — адрес фронтенда (Vercel) для production
CLIENT_ORIGIN=http://localhost:5500
